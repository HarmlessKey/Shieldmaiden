{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Test suite (with emulators)",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["test"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug current test file (emulators must be running)",
			"program": "${workspaceFolder}/node_modules/.bin/jest",
			"args": ["--runInBand", "--watch", "${relativeFile}"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
