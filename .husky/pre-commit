#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run the store + service test suite against the Firebase emulator before every
# commit. Set SKIP_TESTS=1 to bypass (e.g. for docs-only / WIP commits).
if [ "$SKIP_TESTS" = "1" ]; then
	echo "⏭  SKIP_TESTS=1 set — skipping pre-commit test run"
	exit 0
fi

echo "🧪 Running store + service tests against the Firebase emulator…"
npm test
